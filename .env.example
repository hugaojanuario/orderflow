# OrderFlow — variáveis de ambiente (visão geral)
# Cada serviço tem o seu próprio .env.example; este arquivo documenta o conjunto.

# --- api (porta 8080) ---
PORT=8080
DATABASE_URL=postgres://orderflow:orderflow@localhost:5432/orderflow?sslmode=disable
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=troque-este-segredo
LOG_LEVEL=info
APP_ENV=development

# --- worker (porta 8081, health/metrics) ---
# PORT=8081
# WORKER_CONCURRENCY=4
# ACCEPT_TIME_SECONDS=2
# PREP_TIME_SECONDS=5
# DELIVERY_TIME_SECONDS=3

# --- web ---
# API_URL é lida em RUNTIME pelo entrypoint do container, que gera o env.js.
# Em desenvolvimento local, edite web/public/env.js.
# API_URL=http://localhost:8080
